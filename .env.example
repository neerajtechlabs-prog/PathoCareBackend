# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=pathcare
DB_PASS=localpass
DB_NAME=pathcare_db

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Cookie Domain
COOKIE_DOMAIN=.pathcare.local

# Node Environment
NODE_ENV=development

# API Port
API_PORT=3001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AWS S3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=pathcare-files-staging
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# MSG91 (SMS)
MSG91_AUTH_KEY=your-msg91-auth-key

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# AWS SES (Email - Optional)
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@pathcare.com

# Demo Tenant Seed Data
DEMO_TENANT_SLUG=demo
DEMO_ADMIN_EMAIL=admin@demo.pathcare.local
DEMO_ADMIN_PASSWORD=Password123!

# Logging
LOG_LEVEL=debug
